rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── helpers ──────────────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isAudit() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'audit';
    }

    function canCloseQueue() {
      return isAdmin() || isAudit();
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isToday(ts) {
      return ts.date() == request.time.date();
    }

    // ── users ─────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid)
        && request.resource.data.role == 'staff';   // self-register as staff only
      allow update: if isAdmin();                    // only admin can change role
      allow delete: if false;
    }

    // ── queues ────────────────────────────────────────────────────────────────
    match /queues/{queueId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() &&
        // closing/reopening a queue requires admin or audit role
        (
          !('status' in request.resource.data) ||
          request.resource.data.status == resource.data.status ||
          canCloseQueue()
        );
      allow delete: if isAdmin();

      // ── media subcollection ───────────────────────────────────────────────
      match /media/{mediaId} {
        allow read: if isAuth();
        allow create: if isAuth();

        // staff: edit own media taken today | admin: edit all
        allow update: if isAdmin() ||
          (isAuth() &&
           resource.data.takenBy == request.auth.uid &&
           isToday(resource.data.takenAt));

        allow delete: if isAdmin() ||
          (isAuth() &&
           resource.data.takenBy == request.auth.uid &&
           isToday(resource.data.takenAt));
      }
    }

    // ── media collection group (for admin export query) ──────────────────────
    // collectionGroup queries require a top-level rule separate from the
    // subcollection rule inside /queues/{queueId}
    match /{path=**}/media/{mediaId} {
      allow read: if isAdmin();
    }

    // ── products ──────────────────────────────────────────────────────────────
    match /products/{productId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── counters (queue code generation) ─────────────────────────────────────
    match /counters/{dateStr} {
      allow read, write: if isAuth();
    }
  }
}
