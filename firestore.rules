rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── helpers ──────────────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isAudit() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'audit';
    }

    function canCloseQueue() {
      return isAdmin() || isAudit();
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isToday(ts) {
      return ts.date() == request.time.date();
    }

    // ── users ─────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid)
        && request.resource.data.role == 'staff';   // self-register as staff only
      allow update: if isAdmin();                    // only admin can change role
      allow delete: if false;
    }

    // ── queues ────────────────────────────────────────────────────────────────
    match /queues/{queueId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() &&
        (
          // no status change — always allowed for auth users
          !('status' in request.resource.data) ||
          request.resource.data.status == resource.data.status ||

          // step 1: open → pending_close (admin or audit, one person)
          (canCloseQueue() &&
           resource.data.status == 'open' &&
           request.resource.data.status == 'pending_close') ||

          // step 2: pending_close → closed (admin or audit, DIFFERENT person)
          (canCloseQueue() &&
           resource.data.status == 'pending_close' &&
           request.resource.data.status == 'closed' &&
           resource.data.firstApproval.uid != request.auth.uid) ||

          // reopen: closed → open (admin or audit)
          (canCloseQueue() &&
           resource.data.status == 'closed' &&
           request.resource.data.status == 'open') ||

          // cancel: open → cancelled (any authenticated user)
          (isAuth() &&
           resource.data.status == 'open' &&
           request.resource.data.status == 'cancelled')
        );
      allow delete: if isAdmin();

      // ── media subcollection ───────────────────────────────────────────────
      match /media/{mediaId} {
        allow read: if isAuth();
        allow create: if isAuth();

        // admin: edit all | audit: update qcStatus only | staff: edit own media taken today
        allow update: if isAdmin() ||
          isAudit() ||
          (isAuth() &&
           resource.data.takenBy == request.auth.uid &&
           isToday(resource.data.takenAt));

        allow delete: if isAdmin() ||
          (isAuth() &&
           resource.data.takenBy == request.auth.uid &&
           isToday(resource.data.takenAt));
      }
    }

    // ── media collection group (for admin export query) ──────────────────────
    // collectionGroup queries require a top-level rule separate from the
    // subcollection rule inside /queues/{queueId}
    match /{path=**}/media/{mediaId} {
      allow read: if isAdmin();
    }

    // ── products ──────────────────────────────────────────────────────────────
    match /products/{productId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── counters (queue code generation) ─────────────────────────────────────
    match /counters/{dateStr} {
      allow read, write: if isAuth();
    }

    // ── storageDeleteQueue ────────────────────────────────────────────────────
    // Client can only enqueue (create). Read/update/delete is Cloud Function only (Admin SDK).
    match /storageDeleteQueue/{docId} {
      allow create: if isAuth();
      allow read, update, delete: if false;
    }
  }
}
