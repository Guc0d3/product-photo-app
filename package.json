{
  "name": "product-photo-design",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "bash deploy.sh",
    "deploy:rules": "firebase deploy --only firestore:rules,storage",
    "deploy:all": "npm run build && firebase deploy",
    "test": "node --experimental-vm-modules node_modules/.bin/jest tests/dateUtils.test.js",
    "test:rules": "firebase emulators:exec --only firestore 'node --experimental-vm-modules node_modules/.bin/jest tests/firestore.rules.test.js'",
    "test:all": "npm test && npm run test:rules",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "transform": {}
  },
  "dependencies": {
    "firebase": "^12.13.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.14",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "postcss": "^8.4.24",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.3.2",
    "vite": "^4.3.9"
  }
}
